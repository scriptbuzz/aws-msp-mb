# Copy to .env (gitignored) and fill in. NEVER commit .env.
# Access is via IAM Identity Center (SSO) — no long-lived keys.
# See docs/AWS_ACCOUNT_SETUP.md.

# AWS SSO profile configured via `aws configure sso` (run `aws sso login --profile mb-msp`)
AWS_PROFILE=mb-msp
AWS_REGION=us-east-1

# Optional portability overrides (defaults shown) — used by scripts/rollout.sh and
# the demo scripts to name/find resources. Change when deploying under a different
# prefix or repo name; REGION_CODE is auto-derived from AWS_REGION (us-east-1 -> use1).
# ORG=mb
# REPO_NAME=aws-msp-mb
# REGION_CODE=use1

# Optional — only if automating GitHub branch protection / change-record setup.
# If unset, those steps are done manually in the GitHub UI.
# GITHUB_TOKEN=

# Run AWS/Terraform commands with the env loaded so the CLI inherits the profile:
#   set -a && source .env && set +a && terraform <cmd>
